---
const {
    badge,
    title,
    highlight,
    description,
    buttonText,
    buttonLink,
    image,
    stats,
} = Astro.props;
---

<section class="hero section">
    <div class="container hero-wrapper">
        <!-- content -->

        <div class="hero-content">
            <span class="hero-badge">
                {badge}
            </span>

            <h1>
                {title}

                <span>{highlight}</span>
            </h1>

            <p>
                {description}
            </p>

            <a href={buttonLink} class="btn-primary">
                {buttonText}
            </a>

            {
                stats.length > 0 && (
                    <div class="hero-stats">
                        {stats.map((item: any) => (
                            <div class="card stat-card">
                                <span class="stat-icon">{item.icon}</span>

                                <div>
                                    <h3>{item.number}</h3>

                                    <p>{item.label}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                )
            }
        </div>

        <!-- image -->

        <div class="hero-image">
            <img src={image} alt={title} loading="eager" />
        </div>
    </div>
</section>

<style>
    .hero-wrapper {
        display: grid;

        grid-template-columns: repeat(2, 1fr);

        align-items: center;

        gap: 4rem;

        min-height: calc(100vh - var(--nav-height));
    }

    .hero-content {
        max-width: 620px;
    }

    .hero-badge {
        display: inline-flex;

        align-items: center;

        gap: 0.5rem;

        padding: 0.55rem 1rem;

        margin-bottom: 1.5rem;

        border-radius: 999px;

        background: rgba(37, 99, 235, 0.08);

        border: 1px solid rgba(37, 99, 235, 0.15);

        color: var(--secondary);

        font-size: 0.9rem;

        font-weight: 600;
    }

    h1 {
        font-size: clamp(3rem, 6vw, 5rem);

        margin-bottom: 1.25rem;

        letter-spacing: -2px;
    }

    h1 span {
        color: var(--secondary);
    }

    .hero-content p {
        max-width: 560px;

        margin-bottom: 2rem;

        font-size: 1.1rem;
    }

    .hero-stats {
        display: grid;

        grid-template-columns: repeat(2, 1fr);

        gap: 1rem;

        margin-top: 2.5rem;
    }

    .stat-card {
        display: flex;

        align-items: center;

        gap: 1rem;
    }

    .stat-icon {
        width: 50px;

        height: 50px;

        display: grid;

        place-items: center;

        border-radius: 12px;

        background: rgba(37, 99, 235, 0.08);

        font-size: 1.2rem;
    }

    .stat-card h3 {
        margin-bottom: 0.1rem;

        font-size: 1.05rem;
    }

    .stat-card p {
        margin: 0;

        font-size: 0.9rem;
    }

    .hero-image img {
        width: 100%;

        max-width: 560px;

        margin-inline: auto;

        filter: drop-shadow(0 30px 40px rgba(37, 99, 235, 0.12));
    }

    @media (max-width: 900px) {
        .hero-wrapper {
            grid-template-columns: 1fr;

            text-align: center;

            gap: 3rem;
        }

        .hero-content {
            margin-inline: auto;
        }

        .hero-content p {
            margin-inline: auto;
        }

        .hero-stats {
            grid-template-columns: 1fr 1fr;
        }

        .hero-image {
            order: -1;
        }
    }

    @media (max-width: 640px) {
        .hero-stats {
            grid-template-columns: 1fr;
        }

        h1 {
            letter-spacing: -1px;
        }
    }
</style>
