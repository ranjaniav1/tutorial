---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] py-8 mt-12">
    <div
        class="max-w-[800px] mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4"
    >
        <p class="text-xs text-neutral-500 uppercase tracking-widest">
            &copy; {year} Ranjani Varsani
        </p>
        <div class="flex gap-4">
            <a
                href="[https://github.com](https://github.com)"
                class="text-xs text-neutral-500 hover:text-white underline underline-offset-4"
                >GitHub</a
            >
            <a href="https:"></a>
        </div>
    </div>
</footer>
