---
import { footerData } from "../data/footer";
---

<footer class="footer">
  <div class="container footer-grid">
    <!-- brand -->

    <div>
      <h2>{footerData.brand.title}</h2>

      <p>
        {footerData.brand.description}
      </p>
    </div>

    <!-- quick links -->

    <div>
      <h4>Quick Links</h4>

      <ul>
        {
          footerData.quickLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- connect -->

    <div>
      <h4>Connect</h4>

      <ul>
        {
          footerData.connectLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    {footerData.copyright}
  </div>
</footer>

<style>
  .footer {
    margin-top: 5rem;

    padding-top: 4rem;

    background: #020617;

    border-top: 1px solid #1e293b;
  }

  .footer-grid {
    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 3rem;
  }

  .footer h2,
  .footer h4 {
    color: white;

    margin-bottom: 1rem;
  }

  .footer p,
  .footer a {
    color: #94a3b8;
  }

  .footer ul {
    list-style: none;
  }

  .footer li {
    margin-bottom: 0.8rem;
  }

  .footer a {
    text-decoration: none;

    transition: var(--transition);
  }

  .footer a:hover {
    color: #38bdf8;
  }

  .footer-bottom {
    margin-top: 3rem;

    padding: 1.5rem;

    text-align: center;

    border-top: 1px solid #1e293b;

    color: #64748b;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
