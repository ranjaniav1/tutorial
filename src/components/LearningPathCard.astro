---
const { title, description, icon, href } = Astro.props;
---

<a href={href} class="card">
  <div class="icon">{icon}</div>

  <h3>{title}</h3>

  <p>{description}</p>

  <span>Start Learning →</span>
</a>

<style>
  .card {
    display: block;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 24px;
    padding: 2rem;
    text-decoration: none;
    transition: 0.3s;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: #38bdf8;
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  h3 {
    color: white;
    margin-bottom: 1rem;
  }

  p {
    color: #94a3b8;
    margin-bottom: 1.5rem;
  }

  span {
    color: #38bdf8;
    font-weight: 600;
  }
</style>
