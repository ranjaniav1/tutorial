---
const { title, image, lessons, slug } = Astro.props;
---

<a href={slug} class="learning-card">
    <div class="card-image">
        <img src={image} alt={title} loading="lazy" />
    </div>

    <div class="card-content">
        <h3>{title}</h3>

        <p>{lessons}+ Lessons</p>
    </div>
</a>

<style>
    .learning-card {
        background: var(--surface);

        border: 1px solid var(--text-border);

        border-radius: var(--radius-md);

        padding: 1.5rem 1rem;

        text-align: center;

        transition: var(--transition);

        box-shadow: var(--shadow-sm);

        display: flex;

        flex-direction: column;

        align-items: center;

        gap: 1rem;
    }

    .learning-card:hover {
        transform: translateY(-5px);

        box-shadow: var(--shadow-md);
    }

    .card-image {
        width: 90px;

        height: 90px;

        display: grid;

        place-items: center;
    }

    .card-image img {
        width: 100%;

        height: 100%;

        object-fit: contain;
    }

    .card-content h3 {
        font-size: 1.1rem;

        margin-bottom: 0.35rem;

        color: var(--text-heading);
    }

    .card-content p {
        font-size: 0.95rem;

        color: var(--text-secondary);

        font-weight: 400;
    }
</style>
